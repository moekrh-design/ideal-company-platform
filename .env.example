# ===== متغيرات البيئة المطلوبة لـ Railway =====

# قاعدة البيانات PostgreSQL (يُضاف تلقائياً عند إضافة PostgreSQL plugin في Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# إعدادات الخادم
PORT=4000
SESSION_DAYS=7

# مدة الاحتفاظ بالنسخ الاحتياطية (بالأيام)
BACKUP_RETENTION_DAYS=30

# إعدادات البريد الإلكتروني (اختياري)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
