server {
    server_name school.darh.net www.school.darh.net;

    client_max_body_size 50M;

    # === Security Headers (at Nginx level) ===
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # === Static files - serve directly ===
    location = /robots.txt {
        alias /var/www/systems/ideal-platform/public/robots.txt;
        add_header Content-Type text/plain;
        access_log off;
    }

    location = /manifest.json {
        alias /var/www/systems/ideal-platform/public/manifest.json;
        add_header Content-Type "application/json; charset=utf-8";
        access_log off;
    }

    location = /favicon.ico {
        alias /var/www/systems/ideal-platform/public/favicon.ico;
        access_log off;
        expires 30d;
        try_files $uri =204;
    }

    # === Proxy to Node.js app ===
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
    }

    location /public/ {
        alias /var/www/systems/ideal-platform/server/public/;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    listen [::]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/school.darh.net/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/school.darh.net/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = school.darh.net) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name school.darh.net www.school.darh.net;
    return 404; # managed by Certbot


}
